# Django Settings
DEBUG=True
DEV_MODE=True
SECRET_KEY=your_secret_key_here

# Database Configuration
# For development (SQLite): SQLite is used by default when DEV_MODE=True
# For production, set DATABASE_URL to your PostgreSQL/MySQL/etc URL

# Example PostgreSQL URL:
# DATABASE_URL=postgres://user:password@localhost:5432/hoop_and_go

# Example MySQL URL:
# DATABASE_URL=mysql://user:password@localhost:3306/hoop_and_go

# Production Settings (only needed when DEV_MODE=False)
# HOSTNAME=yourdomain.com
# DATABASE_URL=your_database_url_here
